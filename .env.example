# DJANGO_THROTTLE_AUTH_LOGIN=10/min
# DJANGO_THROTTLE_PASSWORD_RESET_REQUEST=3/min
# DJANGO_THROTTLE_PASSWORD_RESET_CONFIRM=5/min
# DJANGO_THROTTLE_FORCE_PASSWORD_CHANGE=5/min
# DJANGO_THROTTLE_CSRF_TOKEN=30/min
